# Copy this file to .env.production, replace every CHANGE_ME value, then run:
# make deploy-public
POSTGRES_DB=evil_repository
POSTGRES_USER=evil_repository
POSTGRES_PASSWORD=CHANGE_ME_LONG_DATABASE_PASSWORD
DATABASE_URL=postgresql+psycopg://evil_repository:CHANGE_ME_LONG_DATABASE_PASSWORD@postgres:5432/evil_repository
APP_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_CHARACTERS
SETUP_TOKEN=CHANGE_ME_ONE_TIME_INITIAL_SETUP_TOKEN

# The project exposes one Web entrypoint. Put your own Caddy, Nginx, Traefik,
# tunnel, or load balancer in front of this port.
WEB_BIND_HOST=0.0.0.0
WEB_BIND_PORT=5173
API_BIND_HOST=127.0.0.1
API_BIND_PORT=8080
WEB_ORIGIN=https://evil.example.com
SESSION_COOKIE_SECURE=true
SESSION_TTL_HOURS=168

ROOTLESS_DOCKER_SOCKET=/run/user/1000/docker.sock
RUNNER_POLL_SECONDS=2
RUNNER_CONCURRENCY=2
SEMANTIC_JUDGE_TIMEOUT=120
SANDBOX_IMAGE=evil-repository-sandbox:local
SANDBOX_MEMORY=268435456
SANDBOX_WORKSPACE_SIZE=1536m
SANDBOX_NANO_CPUS=500000000
SANDBOX_PIDS_LIMIT=256
SANDBOX_TOOL_TIMEOUT=30
SANDBOX_HARD_TIMEOUT=10800
