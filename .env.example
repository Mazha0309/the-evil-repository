POSTGRES_DB=evil_repository
POSTGRES_USER=evil_repository
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://evil_repository:change-me@postgres:5432/evil_repository
APP_SECRET=replace-with-at-least-32-random-characters
SETUP_TOKEN=
SESSION_COOKIE_SECURE=false
SESSION_TTL_HOURS=168
DOCKER_HOST=unix:///var/run/docker.sock
ROOTLESS_DOCKER_SOCKET=/run/user/1000/docker.sock
API_BIND_HOST=127.0.0.1
API_BIND_PORT=8080
WEB_BIND_HOST=127.0.0.1
WEB_BIND_PORT=5173
WEB_ORIGIN=http://127.0.0.1:5173
RUNNER_POLL_SECONDS=2
SEMANTIC_JUDGE_TIMEOUT=120
SANDBOX_IMAGE=evil-repository-sandbox:local
SANDBOX_MEMORY=268435456
SANDBOX_WORKSPACE_SIZE=1536m
SANDBOX_NANO_CPUS=500000000
SANDBOX_PIDS_LIMIT=256
SANDBOX_TOOL_TIMEOUT=30
SANDBOX_HARD_TIMEOUT=4800
